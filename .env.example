# Copy to .env and adjust. Do not commit .env.

# Public URLs (nginx server_name, CORS, Next build)
PUBLIC_DOMAIN=localhost
PUBLIC_URL=http://localhost:8080
HTTP_PORT=8080
HTTPS_PORT=8443

# HTTPS (nginx): mount PEMs into ./nginx/certs and set ENABLE_NGINX_SSL=1
ENABLE_NGINX_SSL=0
SSL_CERTIFICATE_PATH=/etc/nginx/certs/fullchain.pem
SSL_CERTIFICATE_KEY_PATH=/etc/nginx/certs/privkey.pem
NGINX_SSL_CERTS_DIR=./nginx/certs

# Comma-separated origins for FastAPI CORS
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# API keys (comma-separated). Used by FastAPI X-API-Key / Bearer.
ADMIN_API_KEYS=change-me-in-production

# PostgreSQL (docker-compose defaults shown)
POSTGRES_USER=findwork
POSTGRES_PASSWORD=findwork
POSTGRES_DB=findwork
DATABASE_URL=postgresql+psycopg://findwork:findwork@db:5432/findwork

# hh.ru API (public); User-Agent must contain contact per hh rules
HH_USER_AGENT=find-work-dashboard/1.0 (contact: you@example.com)

# LLM: openai | gigachat | none (дублируется в UI → app_setting)
LLM_PROVIDER=gigachat
OPENAI_API_KEY=
# Модель OpenAI по умолчанию (дешёвый tier, удобно под лимит ~1 запрос / 3 мин в UI)
OPENAI_MODEL=gpt-3.5-turbo
# GigaChat-2: готовый Base64-ключ (Authorization Basic) или GIGACHAT_CLIENT_ID + GIGACHAT_CLIENT_SECRET
GIGACHAT_AUTH_KEY=
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=
GIGACHAT_MODEL=GigaChat-2
GIGACHAT_SCOPE=GIGACHAT_API_PERS
# Для шлюза Сбера часто нужен false (MITM/корпоративный SSL); true — только если цепочка доверенная
GIGACHAT_VERIFY_SSL=false
# Минимальный интервал между вызовами LLM (сек). 180 ≈ одна вакансия с анализом раз в 3 минуты
DEFAULT_LLM_MIN_INTERVAL_SECONDS=180

# Опционально: вебхук при ошибках синка (JSON {"text","source"}; совместимо с многими Slack-интеграциями)
ALERT_WEBHOOK_URL=

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Next.js (build-time)
NEXT_PUBLIC_APP_URL=http://localhost:8080
# Браузерный префикс API (nginx проксирует /api/v1 → api:8000)
NEXT_PUBLIC_API_BASE=/api/v1
# Локально без nginx: NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000/api/v1
